{
    "name": "kaho88/seat-manualpap",
    "description": "Manual PAP insertion plugin for SeAT (works with seat-calendar).",
    "type": "seat-plugin",
    "keywords": [
        "seat",
        "eve-online",
        "pap",
        "calendar",
        "plugin"
    ],
    "homepage": "https://github.com/kaho88/seat-manualpap",
    "license": "GPL-3.0-only",

    "autoload": {
        "psr-4": {
            "Seat\\ManualPap\\": "src/"
        }
    },

    "require": {
        "eveseat/web": "^5",
        "eveseat/eveapi": "^5",
        "eveseat/services": "^5"
    },

    "minimum-stability": "stable",
    "prefer-stable": true,

    "extra": {
        "laravel": {
            "providers": [
                "Seat\\ManualPap\\ManualPapServiceProvider"
            ]
        }
    }
}
